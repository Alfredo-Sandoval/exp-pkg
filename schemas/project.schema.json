{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Posetta PROJECT.json",
  "description": "Schema for the public Posetta v1 workspace descriptor.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "format": {
      "type": "string",
      "const": "posetta-project",
      "description": "Locked public descriptor type for Posetta workspaces."
    },
    "project_schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Public PROJECT.json schema version."
    },
    "layout_version": {
      "type": "integer",
      "const": 1,
      "description": "Public workspace layout version."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable project title."
    },
    "project_id": {
      "type": "string",
      "description": "Stable project identifier. UUID and ULID forms are accepted.",
      "pattern": "^(?:[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|[0-9A-HJKMNP-TV-Z]{26})$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$",
      "description": "Project creation timestamp in UTC."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$",
      "description": "Last update timestamp in UTC."
    },
    "store_path": {
      "type": "string",
      "const": ".posetta",
      "description": "Relative path to the private authoritative store."
    },
    "media_root": {
      "type": "string",
      "const": "Media",
      "description": "Standard relative path for managed media."
    },
    "exports_root": {
      "type": "string",
      "const": "Exports",
      "description": "Standard relative path for exported artifacts."
    },
    "default_pack_mode": {
      "type": "string",
      "enum": [
        "portable",
        "snapshot"
      ],
      "default": "portable",
      "description": "Default pack/export mode for the workspace."
    }
  },
  "required": [
    "format",
    "project_schema_version",
    "layout_version",
    "title",
    "project_id",
    "created_at",
    "updated_at",
    "store_path",
    "media_root",
    "exports_root",
    "default_pack_mode"
  ],
  "examples": [
    {
      "format": "posetta-project",
      "project_schema_version": 1,
      "layout_version": 1,
      "title": "My Project",
      "project_id": "01JPKB4QH3Y3FQ1XCB4Q9D4YJ7",
      "created_at": "2026-03-15T00:00:00Z",
      "updated_at": "2026-03-15T00:00:00Z",
      "store_path": ".posetta",
      "media_root": "Media",
      "exports_root": "Exports",
      "default_pack_mode": "portable"
    }
  ]
}
