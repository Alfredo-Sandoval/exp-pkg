{
  "io_formats": {
    "formats": {
      "siesta_json": {
        "default": "skeleton.json",
        "filter": "Siesta skeleton JSON (*.json);;All Files (*)",
        "suffixes": [".json"]
      },
      "siesta_yaml": {
        "default": "skeleton_siesta.yaml",
        "filter": "Siesta skeleton YAML (*.yml *.yaml);;All Files (*)",
        "suffixes": [".yaml", ".yml"]
      },
      "dlc": {
        "default": "skeleton_dlc.yaml",
        "filter": "DeepLabCut skeleton (*.yml *.yaml);;All Files (*)",
        "suffixes": [".yaml", ".yml"]
      },
      "sleap_yaml": {
        "default": "skeleton_sleap.yaml",
        "filter": "SLEAP skeleton YAML (*.yml *.yaml);;All Files (*)",
        "suffixes": [".yaml", ".yml"]
      },
      "sleap_slp": {
        "default": "skeleton.pkg.slp",
        "filter": "SLEAP package (*.pkg.slp);;All Files (*)",
        "suffixes": [".pkg.slp"]
      },
      "sleap_nwb": {
        "default": "skeleton.nwb",
        "filter": "NWB pose file (*.nwb);;All Files (*)",
        "suffixes": [".nwb"]
      },
      "ultralytics_yaml": {
        "default": "skeleton_yolo_pose.yaml",
        "filter": "Ultralytics pose YAML (*.yml *.yaml);;All Files (*)",
        "suffixes": [".yaml", ".yml"]
      },
      "labelstudio_json": {
        "default": "skeleton_labelstudio.json",
        "filter": "Label Studio JSON (*.json);;All Files (*)",
        "suffixes": [".json"]
      }
    }
  },
  "metrics": {
    "metric_types": {
      "pixel_error": "prediction_errors",
      "temporal_norm": "temporal_norm",
      "pca_singleview": "pca_singleview_error"
    }
  },
  "dialogs": {
    "video_export_extensions": [".avi", ".mp4"]
  },
  "visual": {
    "colormaps": [
      "tab10",
      "Set1",
      "Set2",
      "Set3",
      "Dark2",
      "Pastel1",
      "Pastel2",
      "viridis",
      "plasma",
      "inferno",
      "magma",
      "cividis",
      "twilight",
      "turbo",
      "hot",
      "cool",
      "jet",
      "gray"
    ]
  },
  "telemetry_patterns": {
    "epoch_pattern": "Epoch\\s*(\\d+)",
    "batch_pattern": "\\b(\\d+)\\s*/\\s*(\\d+)\\b",
    "train_loss_patterns": [
      "train_supervised_loss\\s*=\\s*([0-9eE+\\-.]+)",
      "train_[A-Za-z0-9_]*?_loss\\s*=\\s*([0-9eE+\\-.]+)",
      "(?<!val[_\\s-])\\b(?:train_loss|loss)\\b\\s*[:=]\\s*([0-9eE+\\-.]+)"
    ],
    "val_loss_patterns": [
      "val_supervised_loss\\s*=\\s*([0-9eE+\\-.]+)",
      "val_[A-Za-z0-9_]*?_loss\\s*=\\s*([0-9eE+\\-.]+)",
      "val[_\\s]?loss\\s*[:=]\\s*([0-9eE+\\-.]+)"
    ]
  }
}
